# MongoDB Connection String
# Get this from MongoDB Atlas after setting up your cluster
# Replace <password> with your database user password
# Replace cogniauthcluster.xxxxx with your actual cluster details
MONGODB_URI=mongodb+srv://cogniauth_user:<password>@cogniauthcluster.xxxxx.mongodb.net/?retryWrites=true&w=majority

# JWT Secret (for token-based authentication)
# Generate a random string from: https://www.uuidgenerator.net/
# This should be a long, random, hard-to-guess string
JWT_SECRET=your_super_secret_jwt_key_change_this_12345

# Server Configuration
PORT=5000
NODE_ENV=development
