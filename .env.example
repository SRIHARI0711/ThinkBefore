# ── MongoDB ────────────────────────────────────────────────────
# Get your URI from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://cogniauth_user:<password>@cogniauthcluster.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Generate a random string: https://www.uuidgenerator.net/
JWT_SECRET=your_super_secret_jwt_key_change_this_12345

PORT=5000
NODE_ENV=development

# ── EmailJS (frontend) ─────────────────────────────────────────
# Sign up free at https://www.emailjs.com/
# Dashboard → Email Services  → Add New Service  → copy Service ID
VITE_EMAILJS_SERVICE_ID=service_xxxxxxx

# Dashboard → Email Templates → Create Template → copy Template ID
# Template 1: OTP email  (variables: to_email, to_name, otp_code, expiry_time)
VITE_EMAILJS_OTP_TEMPLATE_ID=template_xxxxxxx

# Template 2: Password reset (variables: to_email, to_name, reset_link, expiry_time)
VITE_EMAILJS_RESET_TEMPLATE_ID=template_xxxxxxx

# Dashboard → Account → General → Public Key
VITE_EMAILJS_PUBLIC_KEY=xxxxxxxxxxxxxxxx
